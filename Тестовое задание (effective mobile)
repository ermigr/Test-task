cup = [1, 1, 2, 2, 2, 2, 3, 3, 3, 4]
avg_cup = sum(cup) / len(cup)
mark = [85, 88, 79, 81, 84, 65, 67, 58, 76, 49]
avg_mark = sum(mark) / len(mark)

up, down_cup, down_mark = [0] * 3
for i in range(len(cup)):
    dif_cup = cup[i] - avg_cup
    dif_mark = mark[i] - avg_mark
    up += dif_cup * dif_mark
    down_cup += dif_cup**2
    down_mark += dif_mark**2
corr = up / (down_cup * down_mark)**0.5
print(corr)
